[Unit]
# Freally Anti-Virus Linux real-time daemon (TASK-073 / TASK-076 — Phase 8).
#
# This unit is installed by the .deb / .rpm postinst at
# `/lib/systemd/system/freallyd.service` and enabled with
# `systemctl enable freallyd.service`. The user-mode UI app's
# start-at-login is governed by `tauri-plugin-autostart` (FR-161 /
# TASK-157) and is independent of this unit.
Description=Freally Anti-Virus real-time daemon
Documentation=https://github.com/MikesRuthless12/freally-av
After=local-fs.target

[Service]
Type=simple
# Run as root so fanotify FAN_MARK_FILESYSTEM works. The daemon drops
# every capability except CAP_SYS_ADMIN at startup (TASK-073).
User=root
Group=root
ExecStart=/usr/bin/freallyd-linux
# TASK-076 — crash budget. Restart on failure; surface > 3
# restarts/hour as a UI badge through the heartbeat IPC frame.
Restart=on-failure
RestartSec=2
StartLimitIntervalSec=3600
StartLimitBurst=10
# Per docs/prd.md § 1.5.4: no kernel module load. Sandboxing options
# below keep the daemon contained even when running with
# CAP_SYS_ADMIN.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictNamespaces=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
# Daemon owns the /run/freallyd directory for the engine IPC socket.
RuntimeDirectory=freallyd
RuntimeDirectoryMode=0750
# Daemon-local sqlite at /var/lib/freallyd/freallyd.db (TASK-238 mount
# preferences, etc.).
StateDirectory=freallyd
StateDirectoryMode=0750

[Install]
WantedBy=multi-user.target
