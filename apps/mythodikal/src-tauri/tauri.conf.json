{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mythodikal Anti-Virus",
  "version": "0.6.0",
  "identifier": "com.mythodikal.av",
  "build": {
    "beforeDevCommand": "pnpm -C ../frontend dev",
    "beforeBuildCommand": "pnpm -C ../frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mythodikal Anti-Virus",
        "width": 1100,
        "height": 720,
        "minWidth": 920,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost; img-src 'self' data: tauri: ipc:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' tauri: ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "msi", "nsis", "dmg", "app"],
    "category": "Utility",
    "shortDescription": "Source-visible anti-virus",
    "longDescription": "Mythodikal Anti-Virus — the fastest source-visible anti-virus for Windows, macOS, and Linux.",
    "copyright": "Copyright (c) 2026 Mike Weaver",
    "publisher": "Mythodikal",
    "homepage": "https://github.com/MikesRuthless12/mythodikal-av",
    "resources": {
      "../../../ATTRIBUTIONS.txt":         "ATTRIBUTIONS.txt",
      "../../../THIRD-PARTY-RUST.txt":     "THIRD-PARTY-RUST.txt",
      "../../../THIRD-PARTY-NPM.txt":      "THIRD-PARTY-NPM.txt",
      "../../../YARA-RULE-AUTHORS.txt":    "YARA-RULE-AUTHORS.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerHooks": "installer-hooks.nsh"
      },
      "allowDowngrades": false
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "frameworks": [],
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MikesRuthless12/mythodikal-av/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQbjEwBG41EGiaSTWW37d3G02hJDR5rK+Ik6bpQqHW/WEZlT58Ogk78",
      "dangerousInsecureTransportProtocol": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
