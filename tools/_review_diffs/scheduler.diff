+    #[test]
+    fn record_fired_advances_last_fired_at() {
+        let conn = open_test_db();
+        let id = insert(&conn, &daily(0, 0)).unwrap();
+        let before = list_all(&conn).unwrap()[0].last_fired_at;
+        assert!(before.is_none());
+        record_fired(&conn, id).unwrap();
+        let after = list_all(&conn).unwrap()[0].last_fired_at;
+        assert!(after.is_some());
+    }
+
+    #[test]
+    fn round_trip_each_kind_through_db() {
+        let conn = open_test_db();
+        let mut s = daily(1, 2);
+        s.kind = ScheduleKind::Weekly {
+            weekdays: vec![0, 6],
+        };
+        let id = insert(&conn, &s).unwrap();
+        let back = list_all(&conn)
+            .unwrap()
+            .into_iter()
+            .find(|r| r.id == id)
+            .unwrap();
+        assert_eq!(
+            back.kind,
+            ScheduleKind::Weekly {
+                weekdays: vec![0, 6]
+            }
+        );
+
+        let mut s = daily(3, 4);
+        s.kind = ScheduleKind::Monthly { day: 15 };
+        s.name = "monthly".into();
+        let id = insert(&conn, &s).unwrap();
+        let back = list_all(&conn)
+            .unwrap()
+            .into_iter()
+            .find(|r| r.id == id)
+            .unwrap();
+        assert_eq!(back.kind, ScheduleKind::Monthly { day: 15 });
+
+        let mut s = daily(5, 6);
+        s.kind = ScheduleKind::OneShot {
+            at_unix: 1_800_000_000,
+        };
+        s.name = "one".into();
+        let id = insert(&conn, &s).unwrap();
+        let back = list_all(&conn)
+            .unwrap()
+            .into_iter()
+            .find(|r| r.id == id)
+            .unwrap();
+        assert_eq!(
+            back.kind,
+            ScheduleKind::OneShot {
+                at_unix: 1_800_000_000
+            }
+        );
+    }
