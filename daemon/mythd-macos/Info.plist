<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mythodikal Anti-Virus macOS real-time daemon (TASK-080, Phase 9 Wave 1).

  This Info.plist describes the opportunistic Endpoint Security system
  extension. Per docs/prd.md § 1.5.4:

    * NOTIFY-only — no AUTH path. The extension subscribes to
      ES_EVENT_TYPE_NOTIFY_{OPEN,EXEC,RENAME,CREATE,WRITE,CLOSE}.
    * NO com.apple.developer.endpoint-security.client entitlement.
      That entitlement requires the paid Apple Developer Program plus
      Apple approval, both forbidden by § 1.5.
    * No NetworkExtension entitlement either (§ 1.5.3, § 1.5.4) —
      TASK-251 stays BLOCKED.

  On stock consumer macOS where the extension fails to load without
  entitlement, `mythd` falls back silently to FSEvents (TASK-079) —
  no UX regression, just less event metadata.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>mythd</string>
    <key>CFBundleIdentifier</key>
    <string>com.mythodikal.mythd</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Mythodikal Real-time Daemon</string>
    <key>CFBundlePackageType</key>
    <string>SYSX</string>
    <key>CFBundleShortVersionString</key>
    <string>0.9.0</string>
    <key>CFBundleVersion</key>
    <string>0.9.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    <key>NSSystemExtensionUsageDescription</key>
    <string>Mythodikal Anti-Virus uses Endpoint Security in NOTIFY-only mode to observe file events for real-time threat detection. No requests are blocked; events are logged and analyzed locally.</string>
    <key>NSEndpointSecurityRequirement</key>
    <dict>
        <key>NSEndpointSecurityEarlyBoot</key>
        <false/>
    </dict>
    <key>NSEndpointSecurityEarlyBoot</key>
    <false/>
    <!--
      No `com.apple.developer.endpoint-security.client` entitlement key
      below. On a stock consumer macOS install the extension will fail
      to load with ES_NEW_CLIENT_RESULT_ERR_NOT_ENTITLED; the daemon
      treats that as `Unavailable` and continues with FSEvents only.
    -->
</dict>
</plist>
